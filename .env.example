# -------------------------------
# Core runtime wiring (non-sensitive)
# -------------------------------
CONFIG_PATH=/app/config/server-config.yaml
CHATSUNE_STRICT_CONFIG=true
ALLOW_INSECURE_ENV_SECRETS=false

# -------------------------------
# Secret file references (non-sensitive path values only)
# -------------------------------
HF_TOKEN_FILE=/run/secrets/hf_token
VLLM_API_KEY_FILE=/run/secrets/vllm_api_key
TS_AUTHKEY_FILE=/run/secrets/ts_authkey

# Debug-only secret overrides (do not persist)
# HF_TOKEN=
# VLLM_API_KEY=

# -------------------------------
# Tailscale runtime (non-sensitive)
# -------------------------------
TS_HOSTNAME=chatsune-server
TS_STATE_DIR=/var/lib/tailscale
TS_EXTRA_ARGS=
TS_USERSPACE=true
TS_ENABLE_HEALTH_CHECK=true
TS_ENABLE_METRICS=false
TS_ACCEPT_DNS=true
